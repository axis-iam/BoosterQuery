<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- Exclude EI/EI2 warnings on Spring @ConfigurationProperties classes.
         These classes require mutable getter/setter by design. -->
    <Match>
        <Class name="com.chaosguide.jpa.booster.config.BoosterQueryProperties"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Class name="com.chaosguide.jpa.booster.config.BoosterQueryProperties$Cache"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>

    <!-- Exclude EI/EI2 on repository query internals (framework plumbing) -->
    <Match>
        <Class name="com.chaosguide.jpa.booster.repository.query.BoosterSqlRepositoryQuery"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2,CT_CONSTRUCTOR_THROW"/>
    </Match>
</FindBugsFilter>
